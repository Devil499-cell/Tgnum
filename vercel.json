{
    "version": 2,
    "functions": {
        "api/number.js": {
            "runtime": "nodejs18.x"
        }
    },
    "routes": [
        {
            "src": "/api/number",
            "dest": "/api/number.js"
        },
        {
            "src": "/(.*)",
            "dest": "/api/number.js"
        }
    ]
}
